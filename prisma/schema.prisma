generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Column {
  id        String   @id @default(uuid())
  title     String
  order     Int
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id              String    @id @default(uuid())
  title           String
  description     String?
  dueDate         DateTime?
  isPriorityToday Boolean   @default(false)
  columnId        String
  column          Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  order           Int
  source          String    @default("kanban")
  assignee        String?
  logoUrl         String?
  notes           String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  tags            TaskTag[]
}

model Tag {
  id    String    @id @default(uuid())
  name  String
  color String
  tasks TaskTag[]
}

model TaskTag {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model DashboardMetric {
  id                  String   @id @default(uuid())
  date                DateTime @default(now())
  leadsTrafego        Int      @default(0)
  leadsIndicacao      Int      @default(0)
  reunioesAgendadas   Int      @default(0)
  reunioesRealizadas  Int      @default(0)
  vendasQtd           Int      @default(0)
  faturamento         Float    @default(0)
  investimentoTrafego Float    @default(0)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DashboardGoal {
  id                  String   @id @default(uuid())
  leads               Int      @default(1000)
  reunioesAgendadas   Int      @default(200)
  reunioesRealizadas  Int      @default(150)
  faturamento         Float    @default(50000)
  
  updatedAt           DateTime @updatedAt
}
