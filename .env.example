# Banco de dados — Neon PostgreSQL
# Cole a connection string do painel Neon > Connection Details > Pooled connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# NextAuth — obrigatório em produção
# Gere um secret seguro com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-um-valor-seguro-gerado-com-openssl"

# URL da aplicação
# Em desenvolvimento: http://localhost:3000
# Em produção (Vercel): https://seu-projeto.vercel.app
NEXTAUTH_URL="https://seu-projeto.vercel.app"
